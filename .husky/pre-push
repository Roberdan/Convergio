#!/usr/bin/env sh
set -e

cd frontend && npm run check && npm test

cd ../backend
# Use venv if available, otherwise create one with test deps
if [ ! -d ".venv" ]; then
  python3 -m venv .venv
  .venv/bin/pip install -q -r requirements-test.txt
fi
PYTHONPATH=src .venv/bin/pytest --tb=short -q --ignore=tests/e2e

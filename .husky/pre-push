#!/usr/bin/env sh
set -e

cd frontend && npm run check && npm test

cd ../backend
# Use venv if available, otherwise create one with minimal deps
if [ ! -d ".venv" ]; then
  python3 -m venv .venv
  .venv/bin/pip install -q pytest pytest-asyncio anyio prometheus_client
fi
PYTHONPATH=src .venv/bin/pytest --tb=short -q
